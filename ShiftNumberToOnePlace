package arraysProblem;

import java.util.Arrays;

public class RotateArray {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		int arr[]= {-1, 0, 3, 6};
		
		for (int i=1;i<arr.length;i++)
		{
			int temp = arr[i];
			arr[i] = arr[i-1];
			arr[i-1]= temp;
		}
		
		System.out.println(Arrays.toString(arr));

	}

}
