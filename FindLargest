package arraysProblem;

public class FindLargest {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		int  arr[] = {8, 10, 5, 7, 9}    ;
		
		int max= arr[0];
		for ( int i=0;i<arr.length;i++)
		{
			if ( arr[i]> max)
				max = arr[i];
		}
		
		System.out.println(max);

	}

}
