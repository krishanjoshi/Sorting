package arraysProblem;

import java.util.Arrays;

public class SortingZerosNOnes {
	
	public static void sortZero(int arr[])
	{
		
		int low = 0, mid = 0, high = arr.length - 1;
		
		while( mid <= high)
		{
			switch (arr[mid])
			{
			   //Swap with low and increment both (low and mid)
			  case 0:
				  int temp = arr[low];
				  arr[low] = arr[mid];
				  arr[mid] = temp;
				  low++;
				  mid++;
				  break;
				  
			  //Do nothing just increment mid;
			  case 1:
				  mid++;
				  break;
				  
			  //swap mid with last, and decrement high.
			  case 2:
				  temp = arr[high];
				  arr[high] = arr[mid];
				  arr[mid] = temp;
				  high--;
				  break;
			
			}
				
				
		}
		
		
		System.out.println(Arrays.toString(arr));
		
	}
	
	

	
	public static void main(String[] args) {
		
		int arr[]= {0, 1, 2, 0, 1, 2};
		sortZero(arr);
	}
}
