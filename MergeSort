package day2;

import java.util.Arrays;

public class MergeSort {
	
	public static void mergeSort(int arr[], int left, int right)
	{
		if ( left >= right )
			return;
		//find the middle of the array.
		int mid = (right + left)/2;
		
		//Sort the two arrays.
		mergeSort(arr, left, mid);
		mergeSort(arr, mid+1, right);
		
		//Create a 2nd array equal to the size of original array.
		int tempArray[]= new int[right - left+1];
		
		//create three pointer, i points first element of first arrray,j points first element of other half; k points to 2nd array first element.
		int i =left, j=mid+1,k=0;
		//compare the elements with each other, if i > j
		// if (i < j )then i++ ; k++
		while( i<=mid && j <=right)
		{
			if (arr[i] < arr[j]) {
				tempArray[k] = arr[i];
				i++;
				k++;
			} else // if ( j> i ) then j++ , k++
			{
				tempArray[k] = arr[j];
				j++;
				k++;
			}
		}
		
		//if anyt of i or j is left ; copy them as is in k :: k++
		while(i<= mid)
		{
			tempArray[k] = arr[i];
			k++;
			i++;
		}
		
		while(j<= right)
		{
			tempArray[k] = arr[j];
			k++;
			j++;
		}
		
		//copy the temp array (2nd array ) to the original array.
		
		for( int index=0;index<tempArray.length;index++)
		{
			arr[index+ left] = tempArray[index];
		}
		
		
		
	}
	
	public static void main(String args[])
	{
		int arr[]= {4,7,9,2,8,1,6,3,5};
		
		System.out.println("unSorted Array is : " + Arrays.toString(arr));

		
		mergeSort(arr, 0, arr.length-1);
		
		System.out.println("Sorted Array is : " + Arrays.toString(arr));
	}

}
