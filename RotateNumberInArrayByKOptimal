package arraysProblem;

import java.util.Arrays;

public class ShiftElementReversing {

	public static void main(String[] args) {
		
		int arr[]= {1, 2, 3, 4, 5, 6, 7};
		
		int left = 0;
		int right = arr.length -1;
		int k=2;
		
		while( right >=left)
		{
			int temp = arr[right];
			arr[right] = arr[left];
			arr[left] = temp;
			
			right --;
			left++;
		}
		System.out.println(Arrays.toString(arr));
    //rotate first K element.
		 left =0;
		 right = k-1;
		 
		 while( right >=left)
			{
				int temp = arr[right];
				arr[right] = arr[left];
				arr[left] = temp;
				
				right --;
				left++;
			}
		 
			System.out.println(Arrays.toString(arr));

		
   //Rotate rest of the element.
		 left = k;
		 right = arr.length-1;
		 while( right >=left)
			{
				int temp = arr[right];
				arr[right] = arr[left];
				arr[left] = temp;
				
				right --;
				left++;
			}
		 
		 
			System.out.println(Arrays.toString(arr));

	}
}
